# ----- Supabase -----
# Project URL  (Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Public anon key (safe to expose in the browser; RLS protects the data)
VITE_SUPABASE_ANON_KEY=your-anon-key

# ----- Cloudinary -----
# Your cloud name (Cloudinary dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# An UNSIGNED upload preset scoped to the 5brushes/artworks folder
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
